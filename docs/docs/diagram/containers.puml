@startuml
!include <C4/C4_Container>


System_Boundary(_88480653,"Платформа"){
    Container(API_backend, "API backend", "Управляет экспериментами, каталогами флагов, событий, метрик и т.д.,\nпринимает решения, обрабатывает события, выдаёт статистику.",$tags="",$techn="Python, Litestar")
    ContainerDb(Main_DB, "Main DB", "Хранит информацию о экспериментах, флагах, типах метрик и событий,\nисторию экспериментов, конфигурации, журналы аудита.",$tags="db",$techn="Postgres")
    ContainerDb(__1eddddd6, "Хранилище событий", "Хранит информацию о полученных событиях и предоставляет\nинтерфейс для запроса аналитики",$tags="db",$techn="ClickHouse")
    ContainerDb(____49a1eb92, "Кэш и вспомогательное хранилище", "Хранит дополнительные данные, необходимые для распределения вариантов",$tags="db",$techn="Redis")
}

System_Boundary(IAP,"IAP"){
    Container(IAP_API_backend, "IAP API backend", "Проксирует аутентифицированные запросы",$tags="",$techn="None")
}


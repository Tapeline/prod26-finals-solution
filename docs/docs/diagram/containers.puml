Person(_671628d4, "Экспериментатор", "Настраивает эксперименты, анализирует результаты.",$tags="")

Person(_db4cc232, "Утверждающий", "Ревьюит эксперименты, одобряет/отклоняет их.",$tags="")

Person(_3b36e8f4, "Наблюдатель", "Читает результаты.",$tags="")

Rel(API_backend, Main_DB, "","")

